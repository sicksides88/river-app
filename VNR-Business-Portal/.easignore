# EAS Build ignore - same as .gitignore but includes .env for react-native-dotenv

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (NOT .env - needed for react-native-dotenv at build time)
.env*.local

# Backup de React Web (temporal)
src_web_backup/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Backend and portals (not needed for mobile build)
backend/
business-portal/
CRM-VNR/
